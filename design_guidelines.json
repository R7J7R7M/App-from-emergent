  "layout_rules": {
    "safe_area": "Always wrap main content in SafeAreaView",
    "padding": "Use 20px padding for screen edges",
    "alignment": "Center content horizontally, but align text left for readability in cards",
    "glassmorphism": "Use Expo BlurView for text containers when the background is a user photo"
  },
  "instructions_to_main_agent": [
    "1. INSTALLATION: Install `nativewind` and `tailwindcss` if possible for easier styling, OR use standard StyleSheet with the variables provided above.",
    "2. FONTS: Load 'Quicksand' and 'Nunito' using `expo-font` in the root `_layout.tsx` or `App.js`.",
    "3. NAVIGATION: Use `expo-router` with a Bottom Tab Navigator. Customize the tab bar to float (margin bottom 20, rounded corners).",
    "4. IMAGES: Use `expo-image` for caching. Use the provided Image URLs for default placeholders.",
    "5. BACKEND: Ensure FastAPI backend serves the 'Piggie Points' and 'Streak' data.",
    "6. ANIMATION: Use `react-native-reanimated` for the Spin Wheel and progress bars.",
    "7. CRITICAL: DO NOT use Shadcn/UI (it is for web). Build custom components using the `View` and `Text` primitives matching the `components` styles defined above.",
    "8. TESTING: Add `testID` to all interactive elements (buttons, inputs) for testing."
  ],
  "universal_guidelines": [
    "Avoid 'AI Slop': No generic lists. Use cards with icons and rich visuals.",
    "Micro-interactions: Add active opacity or scale animation on button press.",
    "Pink Aesthetic: Stick to the defined palette. Avoid harsh blacks (#000000). Use #4A4A4A or #5D4037 instead."
  ]
}